# --- STONHUB API ---
PORT=8080

# AI via OpenRouter (Claude Haiku 4.5)
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_REFERER=https://stonhub.xyz

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# Helius (Solana RPC + enriched txns)
HELIUS_API_KEY=xxxx

# CORS — your Hostinger frontend origin(s), comma-separated
CORS_ORIGIN=https://stonhub.xyz

# --- $STON holder gating ---
# Leave STON_MINT empty pre-launch (gating off, everyone = free, no errors).
# Set to the token mint (CA) at launch to turn gating on.
STON_MINT=
TIER_HOLDER_MIN=50000
TIER_PRO_MIN=500000

# daily scan limits per tier
FREE_SCAN_LIMIT=5
HOLDER_SCAN_LIMIT=100
PRO_SCAN_LIMIT=1000

# --- whale watch ---
WHALE_MIN_SOL=1000
DEFAULT_WHALE_TARGET=

# --- scan cache (ms) ---
SCAN_CACHE_TTL_MS=300000
